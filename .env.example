# ============================================================
# LLM Server Configuration
# ============================================================
# LM Studio:     http://localhost:1234/v1
# Lemonade:      http://localhost:8000/api/v1  (default port)
LLM_SERVER_URL=http://localhost:1234/v1

# Model name (adjust based on your loaded model)
LLM_MODEL=gpt-3.5-turbo

# ============================================================
# Stable Diffusion API (AUTOMATIC1111 Web UI)
# ============================================================
# Start A1111 with: --api flag
# Example: python launch.py --api
SD_API_URL=http://localhost:7860

# ============================================================
# API Server Configuration
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# ============================================================
# HTTPS Configuration
# ============================================================
# Set HTTPS_ENABLED=true to serve the app over HTTPS.
# If SSL_CERTFILE / SSL_KEYFILE are left empty, a self-signed
# certificate is generated automatically in the ssl/ directory
# (requires openssl to be installed).
# For production, supply paths to a CA-signed certificate.
HTTPS_ENABLED=false
#SSL_CERTFILE=/path/to/cert.pem
#SSL_KEYFILE=/path/to/key.pem

# ============================================================
# Rate Limiting
# ============================================================
# Set RATE_LIMIT_ENABLED=false to disable rate limiting entirely.
# RATE_LIMIT_GENERATION: max requests per minute for image-generation endpoints
#   (/api/sd/generate, /api/sd/img2img, /api/sd/inpaint, /api/generate-prompts)
# RATE_LIMIT_API: max requests per minute for all other /api/* endpoints
# Static files and non-API paths are never rate-limited.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GENERATION=10
RATE_LIMIT_API=60
