# ============================================================
# LLM Server Configuration
# ============================================================
# LM Studio:     http://localhost:1234/v1
# Lemonade:      http://localhost:8000/api/v1  (default port)
LLM_SERVER_URL=http://localhost:1234/v1

# Model name (adjust based on your loaded model)
LLM_MODEL=gpt-3.5-turbo

# ============================================================
# LLM Provider Selection
# ============================================================
# Available providers: openai_compatible, anthropic, gemini
# openai_compatible: LM Studio, Ollama, vLLM, or any OpenAI-compatible server
# anthropic: Anthropic Claude API (requires ANTHROPIC_API_KEY)
# gemini: Google Gemini API (requires GEMINI_API_KEY)
LLM_PROVIDER=openai_compatible

# ============================================================
# Anthropic Claude Configuration
# ============================================================
# Get your API key from: https://console.anthropic.com/
#ANTHROPIC_API_KEY=sk-ant-xxxxx
#ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ============================================================
# Google Gemini Configuration
# ============================================================
# Get your API key from: https://aistudio.google.com/apikey
#GEMINI_API_KEY=AIzaxxxxx
#GEMINI_MODEL=gemini-2.5-flash

# ============================================================
# Stable Diffusion API (AUTOMATIC1111 Web UI)
# ============================================================
# Start A1111 with: --api flag
# Example: python launch.py --api
SD_API_URL=http://localhost:7860

# ============================================================
# API Server Configuration
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# ============================================================
# CORS / Proxy Configuration
# ============================================================
# Comma-separated list of allowed browser origins. Use explicit origins in production.
CORS_ALLOWED_ORIGINS=*
# Enable only when credentialed browser requests are required and origins are restricted.
CORS_ALLOW_CREDENTIALS=false
# Trust X-Forwarded-For / X-Real-IP only when running behind a trusted reverse proxy.
TRUST_PROXY_HEADERS=false

# ============================================================
# HTTPS Configuration
# ============================================================
# Set HTTPS_ENABLED=true to serve the app over HTTPS.
# If SSL_CERTFILE / SSL_KEYFILE are left empty, a self-signed
# certificate is generated automatically in the ssl/ directory
# (requires openssl to be installed).
# For production, supply paths to a CA-signed certificate.
HTTPS_ENABLED=false
#SSL_CERTFILE=/path/to/cert.pem
#SSL_KEYFILE=/path/to/key.pem

# ============================================================
# Rate Limiting
# ============================================================
# Set RATE_LIMIT_ENABLED=false to disable rate limiting entirely.
# RATE_LIMIT_GENERATION: max requests per minute for image-generation endpoints
#   (/api/sd/generate, /api/sd/img2img, /api/sd/inpaint, /api/generate-prompts)
# RATE_LIMIT_API: max requests per minute for all other /api/* endpoints
# Static files and non-API paths are never rate-limited.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GENERATION=10
RATE_LIMIT_API=60

# ============================================================
# Webhook Notifications
# ============================================================
# Leave WEBHOOK_URL empty to disable webhook notifications entirely.
# WEBHOOK_EVENTS: comma-separated list of events to notify on.
#   Available: job_completed, job_failed, job_cancelled, batch_completed
#   (job_cancelled is off by default — add it to opt in)
# WEBHOOK_FORMAT: generic, discord, or slack
# WEBHOOK_TIMEOUT: request timeout in seconds
#WEBHOOK_URL=https://example.com/webhook
WEBHOOK_EVENTS=job_completed,job_failed,batch_completed
WEBHOOK_FORMAT=generic
WEBHOOK_TIMEOUT=5

# ============================================================
# Backup / Restore
# ============================================================
# Directory where backup zip archives are stored (default: data/backups).
#BACKUP_DIR=/path/to/backups
# Set AUTO_BACKUP_ENABLED=true to periodically create backups automatically.
AUTO_BACKUP_ENABLED=false
# Number of automatic backups to keep (oldest beyond this are deleted).
AUTO_BACKUP_RETENTION=7
# Hours between automatic backups.
AUTO_BACKUP_INTERVAL_HOURS=24
# Maximum accepted size (bytes) for a backup archive uploaded for restore.
MAX_BACKUP_UPLOAD_SIZE=2147483648
